# ─── AI Provider ──────────────────────────────────────
# "mock" = deterministic demo output, no API key needed
# "openai" = calls OpenAI-compatible API (DeepSeek, OpenAI, etc.)
NUXT_PUBLIC_AI_PROVIDER=mock

# DeepSeek (recommended for Chinese enterprise scenarios)
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=deepseek-chat

# OpenAI (alternative)
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ─── Data Provider ────────────────────────────────────
# "memory" = in-memory seed data (default, no setup needed)
# "supabase" = PostgreSQL via Supabase (requires Supabase project)
DATA_PROVIDER=memory

# Supabase (only needed when DATA_PROVIDER=supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ⚠️ Never commit real API keys or service role keys to Git
